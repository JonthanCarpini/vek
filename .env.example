# Database
DATABASE_URL="mysql://root:root@localhost:3306/mesa_digital"

# Auth
JWT_SECRET="change-me-to-a-strong-secret-min-32-chars"
JWT_SESSION_SECRET="another-secret-for-client-sessions-32-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
PORT=3000

# Admin padrão (criado no seed)
SEED_ADMIN_EMAIL="admin@mesadigital.com"
SEED_ADMIN_PASSWORD="admin123"

# iFood Merchant API
# Credenciais obtidas no Portal do Desenvolvedor iFood (https://developer.ifood.com.br)
# Sandbox: https://merchant-api.ifood.com.br (mesmo URL, o que muda é a aplicação)
IFOOD_API_URL="https://merchant-api.ifood.com.br"
IFOOD_CLIENT_ID=""
IFOOD_CLIENT_SECRET=""
# Intervalo em milissegundos entre cada polling de eventos (mínimo recomendado: 30000)
IFOOD_POLLING_INTERVAL_MS=30000
