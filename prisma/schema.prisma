generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Credenciais globais iFood (uma app por tenant, gerencia N merchants/Units)
  ifoodClientId     String?
  ifoodClientSecret String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  units     Unit[]
}

model Unit {
  id                    String    @id @default(cuid())
  tenantId              String
  name                  String
  address               String?
  phone                 String?
  whatsapp              String?
  whatsappEnabled       Boolean   @default(false)
  whatsappStatus        String    @default("disconnected") // disconnected | qr | connected
  whatsappSession       String?   @db.Text
  instagram             String?
  logoUrl               String?
  primaryColor          String?   @default("#ea580c")
  timezone              String    @default("America/Sao_Paulo")
  serviceFee            Decimal   @default(0.10) @db.Decimal(5, 4)
  active                Boolean   @default(true)
  // Métodos de pagamento habilitados (CSV: cash,credit,debit,pix,voucher)
  paymentMethods        String    @default("cash,credit,debit,pix")
  // Gateway online
  onlinePaymentEnabled  Boolean   @default(false)
  onlinePaymentProvider String? // "mercadopago" | "asaas"
  mpAccessToken         String?   @db.Text
  mpPublicKey           String?
  asaasApiKey           String?   @db.Text
  asaasWebhookToken     String?
  // Integração iFood
  ifoodEnabled          Boolean   @default(false)
  ifoodMerchantId       String?
  ifoodAutoConfirm      Boolean   @default(false)
  ifoodStoreStatus      String    @default("unknown") // unknown | open | closed | paused
  ifoodLastPollAt       DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  users         User[]
  tables        TableEntity[]
  categories    Category[]
  products      Product[]
  orders        Order[]
  sessions      TableSession[]
  calls         Call[]
  storeDays     StoreDay[]
  businessHours BusinessHours[]
  overrides     StoreOverride[]
  ingredients   Ingredient[]
  displayItems  DisplayItem[]
  customers     Customer[]
  ifoodEvents   IfoodEvent[]
  ifoodTokens   IfoodToken[]

  @@index([tenantId])
}

model User {
  id           String   @id @default(cuid())
  unitId       String?
  name         String
  email        String   @unique
  passwordHash String
  role         String // super_admin | admin | manager | waiter | kitchen | cashier
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  unit Unit? @relation(fields: [unitId], references: [id])

  @@index([unitId])
  @@index([role])
}

model TableEntity {
  id        String   @id @default(cuid())
  unitId    String
  number    Int
  label     String?
  qrToken   String   @unique
  status    String   @default("free") // free | occupied | disabled | reserved
  capacity  Int      @default(4)
  virtual   Boolean  @default(false) // mesa virtual para canais externos (ifood, delivery)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit     Unit           @relation(fields: [unitId], references: [id])
  sessions TableSession[]
  orders   Order[]
  calls    Call[]

  @@unique([unitId, number])
  @@index([qrToken])
}

model TableSession {
  id            String    @id @default(cuid())
  tableId       String
  unitId        String
  customerId    String?
  customerName  String
  customerPhone String
  status        String    @default("active") // active | closing | closed | cancelled
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  totalAmount   Decimal   @default(0) @db.Decimal(12, 2)

  table    TableEntity      @relation(fields: [tableId], references: [id])
  unit     Unit             @relation(fields: [unitId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  orders   Order[]
  calls    Call[]
  payments SessionPayment[]

  @@index([tableId, status])
  @@index([unitId, status])
  @@index([customerId])
}

model SessionPayment {
  id              String   @id @default(cuid())
  sessionId       String
  storeDayId      String?
  method          String // cash | credit | debit | pix | voucher | other
  amount          Decimal  @db.Decimal(12, 2)
  changeGiven     Decimal  @default(0) @db.Decimal(12, 2)
  reference       String? // NSU, txid, etc
  partLabel       String? // "Pessoa 1", etc
  notes           String?  @db.Text
  createdByUserId String?
  createdAt       DateTime @default(now())

  session  TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  storeDay StoreDay?    @relation(fields: [storeDayId], references: [id])

  @@index([sessionId])
  @@index([storeDayId])
}

model StoreDay {
  id             String    @id @default(cuid())
  unitId         String
  openedAt       DateTime  @default(now())
  openedByUserId String
  closedAt       DateTime?
  closedByUserId String?
  openingCash    Decimal   @default(0) @db.Decimal(12, 2)
  closingCash    Decimal?  @db.Decimal(12, 2)
  expectedCash   Decimal?  @db.Decimal(12, 2)
  cashDiff       Decimal?  @db.Decimal(12, 2)
  totalSales     Decimal?  @db.Decimal(12, 2)
  notes          String?   @db.Text
  status         String    @default("open") // open | closed

  unit     Unit             @relation(fields: [unitId], references: [id])
  payments SessionPayment[]

  @@index([unitId, status])
  @@index([unitId, openedAt])
}

model BusinessHours {
  id        String  @id @default(cuid())
  unitId    String
  weekday   Int // 0..6 (dom..sáb)
  openTime  String // "HH:mm"
  closeTime String // "HH:mm"
  active    Boolean @default(true)

  unit Unit @relation(fields: [unitId], references: [id])

  @@unique([unitId, weekday])
}

model StoreOverride {
  id              String    @id @default(cuid())
  unitId          String
  type            String // "open" | "closed"
  reason          String
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  createdByUserId String

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId, endsAt])
}

model Category {
  id        String   @id @default(cuid())
  unitId    String
  name      String
  sortOrder Int      @default(0)
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit     Unit      @relation(fields: [unitId], references: [id])
  products Product[]

  @@index([unitId, active])
}

model Product {
  id                 String    @id @default(cuid())
  unitId             String
  categoryId         String
  name               String
  description        String?   @db.Text
  price              Decimal   @db.Decimal(10, 2)
  imageUrl           String?
  active             Boolean   @default(true)
  available          Boolean   @default(true)
  preparationTimeMin Int       @default(15)
  station            String    @default("cozinha") // cozinha | bar | grill
  tags               String?   @db.Text
  featured           Boolean   @default(false)
  videoUrl           String?
  sortOrder          Int       @default(0)
  // Integração iFood (Catálogo)
  ifoodItemId        String? // id do item publicado no iFood
  ifoodPublished     Boolean   @default(false)
  ifoodLastSyncAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  unit        Unit                @relation(fields: [unitId], references: [id])
  category    Category            @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  ingredients ProductIngredient[]

  @@index([unitId, categoryId, active])
}

model Ingredient {
  id            String   @id @default(cuid())
  unitId        String
  name          String
  unitOfMeasure String   @default("un") // un | g | kg | ml | L
  stock         Decimal  @default(0) @db.Decimal(12, 3)
  minStock      Decimal  @default(0) @db.Decimal(12, 3)
  cost          Decimal  @default(0) @db.Decimal(12, 4)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  unit     Unit                @relation(fields: [unitId], references: [id])
  products ProductIngredient[]

  @@unique([unitId, name])
  @@index([unitId, active])
}

model ProductIngredient {
  id           String  @id @default(cuid())
  productId    String
  ingredientId String
  quantity     Decimal @db.Decimal(12, 3)
  optional     Boolean @default(false)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId])
  @@index([ingredientId])
}

model Order {
  id              String    @id @default(cuid())
  sessionId       String
  unitId          String
  tableId         String
  sequenceNumber  Int
  status          String    @default("received") // received | accepted | preparing | ready | delivered | cancelled
  priority        Int       @default(0)
  subtotal        Decimal   @db.Decimal(12, 2)
  serviceFee      Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @db.Decimal(12, 2)
  notes           String?   @db.Text
  acceptedAt      DateTime?
  readyAt         DateTime?
  deliveredAt     DateTime?
  // Canal de origem do pedido
  channel         String    @default("dine_in") // dine_in | ifood | delivery
  // Dados iFood (quando channel=ifood)
  ifoodOrderId    String?   @unique
  ifoodDisplayId  String? // id curto exibido ao cliente iFood (ex: AB12)
  ifoodStatus     String? // status retornado pelo iFood (PLACED, CONFIRMED, DISPATCHED, etc.)
  customerName    String?
  customerPhone   String?
  deliveryAddress String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  session TableSession @relation(fields: [sessionId], references: [id])
  unit    Unit         @relation(fields: [unitId], references: [id])
  table   TableEntity  @relation(fields: [tableId], references: [id])
  items   OrderItem[]

  @@index([unitId, status, createdAt])
  @@index([sessionId])
  @@index([channel, unitId])
  @@index([ifoodOrderId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String
  name       String // snapshot
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  notes      String?  @db.Text
  status     String   @default("pending") // pending | preparing | ready | delivered
  station    String   @default("cozinha")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Call {
  id               String    @id @default(cuid())
  sessionId        String
  tableId          String
  unitId           String
  type             String // waiter | bill | help
  reason           String?   @db.Text // motivo livre (ex.: "mais guardanapos", "trocar copo")
  paymentHint      String? // quando type=bill: cash|credit|debit|pix|split|online (apenas hint)
  splitCount       Int? // quando paymentHint=split: qtd de partes sugerida
  status           String    @default("pending") // pending | attended | cancelled
  attendedAt       DateTime?
  attendedByUserId String?
  createdAt        DateTime  @default(now())

  session TableSession @relation(fields: [sessionId], references: [id])
  table   TableEntity  @relation(fields: [tableId], references: [id])
  unit    Unit         @relation(fields: [unitId], references: [id])

  @@index([unitId, status, createdAt])
}

model Customer {
  id          String   @id @default(cuid())
  unitId      String
  name        String
  phone       String
  email       String?
  notes       String?  @db.Text
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  totalSpent  Decimal  @default(0) @db.Decimal(12, 2)
  totalOrders Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit     Unit           @relation(fields: [unitId], references: [id])
  sessions TableSession[]

  @@unique([unitId, phone])
  @@index([unitId, name])
}

model DisplayItem {
  id          String   @id @default(cuid())
  unitId      String
  type        String // "image" | "video"
  url         String
  durationSec Int      @default(8) // usado para imagens
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  title       String?
  subtitle    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId, active, sortOrder])
}

// Cache do token OAuth do iFood por unidade (ou global se unitId=null)
model IfoodToken {
  id          String   @id @default(cuid())
  unitId      String? // null = token global (credenciais do .env)
  accessToken String   @db.Text
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit Unit? @relation(fields: [unitId], references: [id])

  @@unique([unitId])
  @@index([expiresAt])
}

// Log de eventos iFood (polling + acknowledgment)
model IfoodEvent {
  id             String    @id @default(cuid())
  unitId         String
  ifoodEventId   String    @unique // id do evento no iFood
  ifoodOrderId   String? // id do pedido relacionado
  code           String // PLC | CFM | CAN | DSP | CON | RPR ...
  fullCode       String? // PLACED | CONFIRMED | ...
  payload        String?   @db.Text // JSON completo do evento
  status         String    @default("pending") // pending | processed | failed | ignored
  errorMessage   String?   @db.Text
  acknowledgedAt DateTime?
  processedAt    DateTime?
  receivedAt     DateTime  @default(now())

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId, status])
  @@index([ifoodOrderId])
  @@index([receivedAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  diff      String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}
